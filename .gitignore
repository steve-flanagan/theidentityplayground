# ---------------------------------------------------------------------------
# Secrets — nothing in this block may ever be committed. See spec section 4.7.
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
# local.settings.json holds Azure Functions connection strings
local.settings.json
appsettings.Development.json
*.publishsettings
*.pubxml
*.pfx
*.p12
*.key
*.pem
secrets.json
**/secrets/
azureauth.json
# A HAR of a sign-in is a credential dump: it carries the authorization code, the
# ID token, session cookies, and possibly the credential POST body. Captures stay
# out of the repo, permanently. Derive timings from them with
# scripts/har-to-timings.mjs and commit only that.
*.har

# ---------------------------------------------------------------------------
# Node / Vite / React  (web/, api/, scim-mock/)
# ---------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
build/
.vite/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache

# ---------------------------------------------------------------------------
# Azure Functions
# ---------------------------------------------------------------------------
bin/
obj/
.azurefunctions/
func-cli.log
.python_packages/

# ---------------------------------------------------------------------------
# Azure / deployment tooling
# ---------------------------------------------------------------------------
.azure/
*.zip
.deployment
swa-cli.config.json.local
# Local one-shot provisioning scratch — public IDs only, but the author's
# disposable copy. The reviewed version lives in the PR and docs, not tracked.
DeleteAfter.ps1

# ---------------------------------------------------------------------------
# Bicep / infra
# ---------------------------------------------------------------------------
*.bicep.json
main.parameters.local.json

# ---------------------------------------------------------------------------
# Editors / OS
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Claude Code — local working config, deliberately NOT published.
# This is a portfolio repo; the working notes and tooling config are for the
# author, not the audience. These files stay on disk, they just stay out of git.
# ---------------------------------------------------------------------------
CLAUDE.md
HANDOFF.md
.claude/
# /notes/ carries verbatim reactions and working history. Anchored with a
# leading slash so it only matches the root dir, never a source subdirectory.
/notes/
